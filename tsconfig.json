{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2015", "ES2022", "DOM"],
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types", "./types"],
    "baseUrl": "./",
    "paths": {
      "@actions/*": ["src/actions/*"],
      "@models/*": ["src/models/*"],
      "@localtypes/*": ["src/types/*"],
      "@parsers/*": ["src/parsers/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
