{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2015", "ES2022", "DOM"],
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types", "./types"],
    "paths": {
      "@actions/*": ["./src/actions/*"],
      "@models/*": ["./src/models/*"],
      "@localtypes/*": ["./src/types/*"],
      "@parsers/*": ["./src/parsers/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src", "types/**/*.d.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
