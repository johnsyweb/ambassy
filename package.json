{
  "name": "ambassy",
  "version": "1.5.0",
  "description": "For ambassador allocations",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config webpack.prod.js && node script/verify-finish-export-userscript-dist.cjs && node script/update-sitemap-lastmod.js",
    "commitlint": "commitlint --edit",
    "deploy": "gh-pages -d dist",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "predeploy": "aube run build",
    "release": "semantic-release",
    "resolve": "tsc --traceResolution",
    "start": "webpack serve --open",
    "start:sourcemaps": "webpack serve --open --devtool source-map",
    "test": "jest",
    "sync:userscript-matches": "node script/sync-finish-export-userscript-matches.cjs",
    "rebuild:userscript": "node script/rebuild-finish-export-userscript.cjs",
    "screenshots": "ts-node -r tsconfig-paths/register script/generate-screenshots.ts",
    "smoke:map-dom-budget": "ts-node -r tsconfig-paths/register script/smoke-map-dom-budget.ts"
  },
  "keywords": [
    "parkrun",
    "ambassador"
  ],
  "author": "",
  "license": "ISC",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "./script/release \"${nextRelease.version}\""
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes.split('\\n').slice(0, 3).join('\\n')}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false,
          "failComment": false,
          "releasedLabels": false
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/connect": "^3.4.38",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.3",
    "@types/papaparse": "^5.5.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.5.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "mini-css-extract-plugin": "^2.10.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "puppeteer": "^25.1.0",
    "semantic-release": "^25.0.5",
    "terser-webpack-plugin": "^5.6.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "d3": "^7.9.0",
    "d3-geo-voronoi": "^2.1.0",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "path-browserify": "^1.0.1",
    "ts-node": "^10.9.2"
  },
  "packageManager": "aube@1.17.1"
}
